{
    "compilerOptions": {
        "moduleResolution": "Bundler",
        "target": "ES2022",
        "module": "preserve",
        "lib": [
            "ES2024",
            "DOM",
            "DOM.Iterable",
            "WebWorker"
        ],
        "isolatedModules": true,
        "moduleDetection": "force",
        "noEmit": true,
        "strict": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "noUnusedLocals": true,
        "noImplicitOverride": true,
        "noImplicitReturns": true
    },
    "include": [
        "*.ts",
        "*.mts",
        "src"
    ]
}
